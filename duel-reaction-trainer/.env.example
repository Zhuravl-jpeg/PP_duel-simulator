# ============================================
# duel-reaction-trainer
# Переменные окружения
# ============================================
# Скопируйте этот файл в .env и заполните значения

# --- База данных (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/duel_reaction_trainer"

# --- Better Auth ---
# Секретный ключ для подписи токенов (сгенерируйте: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-key-here"

# URL приложения (для продакшена укажите реальный домен)
BETTER_AUTH_URL="http://localhost:3000"

# --- Сессия (опционально, для Cookie) ---
# BETTER_AUTH_SECRET можно также задать через BETTER_AUTH_SECRET
