# ============================================
# duel-reaction-trainer
# Переменные окружения
# ============================================
# Скопируйте этот файл в .env (для продакшена) или .env.local (для локальной разработки)

# --- База данных (PostgreSQL) ---
# Локально (offline):
DATABASE_URL="postgresql://postgres:password@localhost:5432/duel_reaction"
# Продакшен (Neon):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/duel_reaction"

# --- Better Auth ---
# Секретный ключ для подписи токенов (сгенерируйте: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-key-here"

# URL приложения:
# Локально (offline):
BETTER_AUTH_URL="http://localhost:3000"
# Продакшен (обязательно HTTPS!):
# BETTER_AUTH_URL="https://yourdomain.com"

# --- Сессия (опционально, для Cookie) ---
# BETTER_AUTH_SECRET можно также задать через BETTER_AUTH_SECRET

# --- Redis (только для продакшена, не нужен локально) ---
# Локально: не нужен (используется Map в памяти)
# Продакшен:
# REDIS_URL="redis://default:password@upstash.io:6379"

# --- Режим ---
NODE_ENV="development"
# Продакшен: NODE_ENV="production"
