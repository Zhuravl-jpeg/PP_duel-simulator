# ============================================
# duel-reaction-trainer
# Переменные окружения
# ============================================
# Скопируйте этот файл в .env.local (для локальной разработки) или .env (для продакшена)

# --- 1. База данных (PostgreSQL) ---
# Локально (Docker): postgresql://postgres:password@localhost:5432/duel_reaction
# Продакшен (Neon):   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/duel_reaction?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/duel_reaction"

# --- 2. Оптимизация пула для Serverless (Vercel/Railway) ---
# Максимум подключений на один процесс (1 для serverless, 5 для локалки)
DB_POOL_MAX=5
# Таймаут освобождения простоящего подключения (мс)
DB_POOL_IDLE_TIMEOUT=1000
# Таймаут ожидания подключения к БД (мс)
DB_POOL_CONNECTION_TIMEOUT=2000

# --- 3. Better Auth (Аутентификация) ---
# Секретный ключ для подписи сессий (сгенерируйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET="change-me-to-a-random-secure-string"

# URL приложения (обязательно HTTPS для продакшена!)
# Локально:
BETTER_AUTH_URL="http://localhost:3000"
# Продакшен:
# BETTER_AUTH_URL="https://yourdomain.com"

# --- 4. Redis (Защита от фальстартов и rate limiting) ---
# Локально (Docker): redis://localhost:6379
# Продакшен (Upstash): redis://default:password@xxx.upstash.io:6379
REDIS_URL="redis://localhost:6379"

# --- 5. OAuth провайдеры (опционально) ---
# Оставьте пустыми, если не используете вход через соцсети. Приложение запустится без них.
GOOGLE_ID=""
GOOGLE_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# --- 6. Режим работы ---
NODE_ENV="development"
# Продакшен: NODE_ENV="production"
