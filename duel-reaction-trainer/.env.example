# ============================================
# duel-reaction-trainer
# Переменные окружения
# ============================================
# Скопируйте этот файл в .env (для продакшена) или .env.local (для локальной разработки)

# --- База данных (PostgreSQL) ---
# Локально (offline):
DATABASE_URL="postgresql://postgres:password@localhost:5432/duel_reaction"
# Продакшен (Neon):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/duel_reaction"

# --- Оптимизация пула для Serverless (Vercel/Railway) ---
# Максимум подключений на один процесс/инстанс (по умолчанию 1 для безопасности cold-start)
DB_POOL_MAX=1
# Таймаут освобождения простоящего подключения (мс)
DB_POOL_IDLE_TIMEOUT=1000
# Таймаут ожидания подключения к БД (мс)
DB_POOL_CONNECTION_TIMEOUT=2000

# --- Better Auth ---
# Секретный ключ для подписи токенов (сгенерируйте: openssl rand -base64 32)
BETTER_AUTH_SECRET="MeZevtjaYQemI4OUqNkEZjf6YhlxFSznnnfnFyT4Vp0="

# URL приложения:
# Локально (offline):
BETTER_AUTH_URL="http://localhost:3000"
# Продакшен (обязательно HTTPS!):
# BETTER_AUTH_URL="https://yourdomain.com"

# --- OAuth (Google) ---
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

# --- OAuth (GitHub) ---
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# --- Сессия (опционально, для Cookie) ---
# BETTER_AUTH_SECRET можно также задать через BETTER_AUTH_SECRET

# --- Redis (только для продакшена, не нужен локально) ---
# Локально: не нужен (пропускается, если не установлен)
# Продакшен:
REDIS_URL="redis://default:password@upstash.io:6379"

# --- Режим ---
NODE_ENV="development"
# Продакшен: NODE_ENV="production"
